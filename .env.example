# Copy to .env and fill in. .env is gitignored.

# Etherscan API (free tier: 5 calls/sec, 100k calls/day)
ETHERSCAN_API_KEY=

# The Graph Decentralized Network (required — the hosted service was
# sunset in 2024). Get a free key at https://thegraph.com/studio —
# the free tier covers 100k queries per month, more than enough here.
THEGRAPH_API_KEY=

# Honeypot.is — public, no key required, but rate-limited
# HONEYPOT_BASE_URL=https://api.honeypot.is

# Local DuckDB file
DB_PATH=data/rug_detector.duckdb

# Optional: override default data dirs
# DATA_RAW_DIR=data/raw
# DATA_PROCESSED_DIR=data/processed
