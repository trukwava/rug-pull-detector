# Secrets
.env

# Data — don't check in raw API dumps or large parquet files.
# The repo ships *empty* data dirs; users hydrate from APIs.
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
*.duckdb
*.duckdb.wal

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
build/
dist/
.venv/
venv/

# Notebooks
.ipynb_checkpoints/

# Editors / OS
.DS_Store
.vscode/
.idea/

# Reports — keep methodology, not generated outputs
reports/*.png
reports/*.csv
!reports/methodology.md
